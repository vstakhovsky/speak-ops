# SpeakOps .gitignore

# System
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
.Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
ENV/
env/
.virtualenv/

# Environment / secrets
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
!.env.example

# Local user data (privacy-first)
data/
*.csv
*.jsonl
*.json
data/raw/
data/private/
data/audio/
data/transcripts/
data/exports/
data/backups/

# User exports
/export/
/exports/

# Output files
/output/
/outputs/
examples/*.generated
examples/*_output

# Logs
*.log
logs/
*.log.*

# Temporary files
.tmp/
.temp/
.cache/
*.tmp
*.temp
*.bak
*.backup

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Claude Code
.claude/cache/
.claude/session/
.claude/transcripts/

# Pre-commit
.pre-commit-cache/

# Documentation builds
docs/_build/
docs/.doctrees/
docs/.cache/

# MacOS
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Node (if ever added)
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
yarn-progress.log
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build artifacts
dist/
build/
*.tgz

# Backup files
*.bak
*.backup
*.old

# Keep example files but ignore generated ones
!examples/
examples/*.generated
examples/*_output

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
